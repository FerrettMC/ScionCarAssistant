<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ScionCarAssistant.MainPage"
             >

<Grid RowDefinitions="Auto,4.5*,Auto,1.1*,1.1*" ColumnDefinitions="*,*" RowSpacing="10" ColumnSpacing="10" Padding="10">
    <!-- Now Playing label - bigger -->
    <Label x:Name="NowPlayingLabel"
           Grid.Row="0" Grid.ColumnSpan="2"
           Text="Nothing playing"
           FontSize="34"
           TextColor="White"
           HorizontalTextAlignment="Center"
           LineBreakMode="WordWrap"
           MaxLines="2" />

    <!-- Push to talk - even more dominant -->
    <Button x:Name="VoiceBtn"
            Grid.Row="1" Grid.ColumnSpan="2"
            Text="PRESS TO TALK"
            FontSize="46"
            BackgroundColor="DarkGreen"
            TextColor="White"
            Clicked="OnVoiceClicked" />

    <!-- Reload - short -->
    <Button x:Name="ReloadBtn"
            Grid.Row="2" Grid.ColumnSpan="2"
            Text="RELOAD"
            FontSize="20"
            HeightRequest="40"
            BackgroundColor="#FF355A50"
            TextColor="White"
            Clicked="Reload" />

    <!-- Play/Pause, Skip -->
    <Button x:Name="PlayPauseBtn"
            Grid.Row="3" Grid.Column="0"
            Text="▶ PLAY"
            FontSize="24"
            BackgroundColor="DarkGreen"
            TextColor="White"
            Clicked="OnPlayPauseClicked" />

    <Button Grid.Row="3" Grid.Column="1"
            Text="⏭ SKIP"
            FontSize="24"
            BackgroundColor="DarkSlateBlue"
            TextColor="White"
            Clicked="OnSkipClicked" />

    <!-- Vol Down, Vol Up - squished -->
    <Button Grid.Row="4" Grid.Column="0"
            Text="🔉 VOL −"
            FontSize="16"
            BackgroundColor="#333"
            TextColor="White"
            Clicked="OnVolumeDownClicked" />

    <Button Grid.Row="4" Grid.Column="1"
            Text="🔊 VOL +"
            FontSize="16"
            BackgroundColor="#333"
            TextColor="White"
            Clicked="OnVolumeUpClicked" />

        <Grid x:Name="PlaylistPopup"
          Grid.Row="0" Grid.RowSpan="5" Grid.Column="0" Grid.ColumnSpan="2"
          BackgroundColor="#DD000000"
          IsVisible="False">
        <VerticalStackLayout x:Name="PlaylistStack"
                              VerticalOptions="Center"
                              Padding="20"
                              Spacing="12" />
    </Grid>

</Grid>
</ContentPage>