<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ScionCarAssistant.MainPage"
             BackgroundColor="Black">

  <Grid RowDefinitions="*,*,*" ColumnDefinitions="*,*" RowSpacing="10" ColumnSpacing="10" Padding="10">

        <!-- Voice assistant toggle - full width top row -->
        <Button x:Name="VoiceBtn"
                Grid.Row="0" Grid.ColumnSpan="2"
                Text="🎤 VOICE OFF"
                FontSize="40"
                BackgroundColor="DarkRed"
                TextColor="White"
                Clicked="OnVoiceClicked" />

        <!-- Middle row: Play/Pause, Skip -->
        <Button x:Name="PlayPauseBtn"
                Grid.Row="1" Grid.Column="0"
                Text="▶ PLAY"
                FontSize="40"
                BackgroundColor="DarkGreen"
                TextColor="White"
                Clicked="OnPlayPauseClicked" />

        <Button Grid.Row="1" Grid.Column="1"
                Text="⏭ SKIP"
                FontSize="40"
                BackgroundColor="DarkSlateBlue"
                TextColor="White"
                Clicked="OnSkipClicked" />

        <!-- Bottom row: Vol Down, Vol Up -->
        <Button Grid.Row="2" Grid.Column="0"
                Text="🔉 VOL −"
                FontSize="35"
                BackgroundColor="#333"
                TextColor="White"
                Clicked="OnVolumeDownClicked" />

        <Button Grid.Row="2" Grid.Column="1"
                Text="🔊 VOL +"
                FontSize="35"
                BackgroundColor="#333"
                TextColor="White"
                Clicked="OnVolumeUpClicked" />

    </Grid>
</ContentPage>