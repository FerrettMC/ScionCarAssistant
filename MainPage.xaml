<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ScionCarAssistant.MainPage"
             >

<Grid RowDefinitions="Auto,Auto,4.5*,Auto,1.1*,1.1*" ColumnDefinitions="*,*" RowSpacing="10" ColumnSpacing="10" Padding="10">

    <HorizontalStackLayout Grid.Row="0" Grid.ColumnSpan="2"
                   HeightRequest="40"
                   Spacing="6"
                   HorizontalOptions="Center"
                   VerticalOptions="Center">
    <BoxView x:Name="Bar1" WidthRequest="20" HeightRequest="6" VerticalOptions="End" Color="#FF3B30" />
    <BoxView x:Name="Bar2" WidthRequest="20" HeightRequest="6" VerticalOptions="End" Color="#FF9500" />
    <BoxView x:Name="Bar3" WidthRequest="20" HeightRequest="6" VerticalOptions="End" Color="#FFCC00" />
    <BoxView x:Name="Bar4" WidthRequest="20" HeightRequest="6" VerticalOptions="End" Color="#34C759" />
    <BoxView x:Name="Bar5" WidthRequest="20" HeightRequest="6" VerticalOptions="End" Color="#00C7BE" />
    <BoxView x:Name="Bar6" WidthRequest="20" HeightRequest="6" VerticalOptions="End" Color="#30ADE6" />
    <BoxView x:Name="Bar7" WidthRequest="20" HeightRequest="6" VerticalOptions="End" Color="#5856D6" />
    <BoxView x:Name="Bar8" WidthRequest="20" HeightRequest="6" VerticalOptions="End" Color="#AF52DE" />
    <BoxView x:Name="Bar9" WidthRequest="20" HeightRequest="6" VerticalOptions="End" Color="#FF2D78" />
</HorizontalStackLayout>
    <!-- Now Playing label - bigger -->
    <Label x:Name="NowPlayingLabel"
           Grid.Row="1" Grid.ColumnSpan="2"
           Text="Nothing playing"
           FontSize="34"
           TextColor="White"
           HorizontalTextAlignment="Center"
           LineBreakMode="WordWrap"
           MaxLines="2" />

    <!-- Push to talk - even more dominant -->
    <Button x:Name="VoiceBtn"
            Grid.Row="2" Grid.ColumnSpan="2"
            Text="PRESS TO TALK"
            FontSize="46"
            BackgroundColor="DarkGreen"
            TextColor="White"
            Clicked="OnVoiceClicked" />

    <!-- Reload - short -->
    <Button x:Name="ReloadBtn"
            Grid.Row="3" Grid.ColumnSpan="2"
            Text="RELOAD"
            FontSize="20"
            HeightRequest="40"
            BackgroundColor="#FF355A50"
            TextColor="White"
            Clicked="Reload" />

    <!-- Play/Pause, Skip -->
    <Button x:Name="PlayPauseBtn"
            Grid.Row="4" Grid.Column="0"
            Text="▶ PLAY"
            FontSize="24"
            BackgroundColor="DarkGreen"
            TextColor="White"
            Clicked="OnPlayPauseClicked" />

    <Button Grid.Row="4" Grid.Column="1"
            Text="⏭ SKIP"
            FontSize="24"
            BackgroundColor="DarkSlateBlue"
            TextColor="White"
            Clicked="OnSkipClicked" />

    <!-- Vol Down, Vol Up - squished -->
    <Button Grid.Row="5" Grid.Column="0"
            Text="🔉 VOL −"
            FontSize="16"
            BackgroundColor="#333"
            TextColor="White"
            Clicked="OnVolumeDownClicked" />

    <Button Grid.Row="5" Grid.Column="1"
            Text="🔊 VOL +"
            FontSize="16"
            BackgroundColor="#333"
            TextColor="White"
            Clicked="OnVolumeUpClicked" />

        <Grid x:Name="PlaylistPopup"
                
          Grid.Row="0" Grid.RowSpan="6" Grid.Column="0" Grid.ColumnSpan="2"
          BackgroundColor="#DD000000"
          IsVisible="False">
          <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnPlaylistPopupTapped" />
        </Grid.GestureRecognizers>
        <VerticalStackLayout x:Name="PlaylistStack"
                              VerticalOptions="Center"
                              Padding="20"
                              Spacing="12" />
    </Grid>
        <Button x:Name="QuickOpenSpotifyBtn"
                Grid.Row="0" Grid.RowSpan="6" Grid.Column="0" Grid.ColumnSpan="2"
                Text="OPEN SPOTIFY"
                FontSize="18"
                HeightRequest="45"
                WidthRequest="200"
                VerticalOptions="End"
                HorizontalOptions="Center"
                Margin="0,0,0,20"
                BackgroundColor="#1DB954"
                TextColor="White"
                Clicked="OnQuickOpenSpotifyClicked"
                IsVisible="True" />

</Grid>
</ContentPage>